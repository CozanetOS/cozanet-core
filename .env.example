# CozanetOS Core — Environment Variables
# Copy to .env and fill in your values

# ── LLM Providers (at least one required) ──────────────────────────────────
# Groq (recommended — free tier, very fast)
# Get your key at: https://console.groq.com
GROQ_API_KEY=

# OpenAI (fallback)
OPENAI_API_KEY=

# xAI / Grok (fallback)
XAI_API_KEY=

# ── Memory / Database ──────────────────────────────────────────────────────
# Path to SQLite database file (persists across restarts)
# Default: ./data/cozanet-memory.db
MEMORY_DB_PATH=./data/cozanet-memory.db

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# ── Frontend URL (for CORS) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
